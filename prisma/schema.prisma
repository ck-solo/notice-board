generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  Exam
  Event
  General
}

enum Priority {
  Normal
  Urgent
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  body        String
  category    Category
  priority    Priority
  publishDate DateTime
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}